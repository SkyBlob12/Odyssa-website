# Modèle de configuration locale — COPIE ce fichier en `.env` et remplis tes clés.
# `.env` est ignoré par Git (jamais commité). Sert uniquement aux tests en local :
#   node --env-file=.env scripts/generate-weekly.mjs
# En production, ces valeurs vivent dans les GitHub Secrets, pas ici.

GROQ_API_KEY=
UNSPLASH_KEY=
NOTION_TOKEN=
NOTION_DB_ID=

# Optionnel : changer de modèle Groq (défaut : llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile
